#!/bin/sh
# =============================================================
# Script Name: MonitorSetup
# Description: Dynamic multi-monitor configuration for bspwm using xrandr
# Features:
#   - Host-specific monitor configuration support
#   - Auto-detect connected monitors (Up to 4 monitors)
#   - Dynamic workspace assignment
#   - Resolution/refresh rate detection
#
# Author: gh0stzk + don (host-specific modifications)
# Repo:   https://github.com/gh0stzk/dotfiles
# Date:   24.04.2025
#
# Copyright (C) 2021-2025 gh0stzk <z0mbi3.zk@protonmail.com>
# Licensed under GPL-3.0 license
# =============================================================

# Configuration file path
CONFIG_FILE="${HOME}/.config/bspwm/monitor-config.conf"

# Default values
AUTO_DETECT=false
MONITOR_MAIN=""
MONITOR_SEC=""
MAIN_WORKSPACES="A B C D E"
SEC_WORKSPACES="F G H I J"
SEC_POSITION="right-of"
MONITOR_ORDER=""

# HDR settings
HDR_MONITOR=""
HDR_ENABLE=false

# Load host-specific configuration if available
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    . "$CONFIG_FILE"
fi

# xrandr cmd
XRANDR_OUTPUT=$(xrandr)

# Remove disconnected monitors
xrandr | while read -r mon state _; do
    [ "$state" = "disconnected" ] && xrandr --output "$mon" --off
done

# Function to obtain monitor info (POSIX-compliant)
get_monitor_info() {
    echo "$XRANDR_OUTPUT" | awk -v monitor="$1" '
        $1 == monitor { getline; print $1, $2 }
    ' | tr -d '*+'
}

# Get connected monitors using POSIX-compliant method
set -- $(echo "$XRANDR_OUTPUT" | awk '$2 == "connected" {print $1}')
NUM_MONITORS=$#

# Auto-detect mode: assign monitors based on connection order
if [ "$AUTO_DETECT" = "true" ] || [ -z "$MONITOR_MAIN" ]; then
    if [ $NUM_MONITORS -ge 1 ]; then
        MONITOR_MAIN="$1"
        if [ $NUM_MONITORS -ge 2 ]; then
            MONITOR_SEC="$2"
        fi
    fi
fi

# Reorder monitors: if specific order requested, apply it
if [ -n "$MONITOR_ORDER" ] && [ $NUM_MONITORS -ge 2 ]; then
    # Parse MONITOR_ORDER and reorder if both monitors are connected
    first_mon=$(echo "$MONITOR_ORDER" | awk '{print $1}')
    second_mon=$(echo "$MONITOR_ORDER" | awk '{print $2}')
    
    # Check if both requested monitors are connected
    if echo "$XRANDR_OUTPUT" | grep -q "^$first_mon connected" && \
       echo "$XRANDR_OUTPUT" | grep -q "^$second_mon connected"; then
        # Reorder to match MONITOR_ORDER
        if [ "$1" = "$second_mon" ] && [ "$2" = "$first_mon" ]; then
            set -- "$first_mon" "$second_mon"
        fi
    fi
fi

# Main case for monitor configuration
case $NUM_MONITORS in
    1)
        monitor_1="${MONITOR_MAIN:-$1}"
        set -- $(get_monitor_info "$monitor_1")
        mode_1="$1"
        rate_1="$2"

        xrandr --output "$monitor_1" --primary --mode "$mode_1" --pos 0x0 --auto --rate "$rate_1"
        bspc monitor "$monitor_1" -d $MAIN_WORKSPACES
        SetMonoclePadding "$monitor_1"
        ;;

    2)
        monitor_main="${MONITOR_MAIN:-$1}"
        monitor_sec="${MONITOR_SEC:-$2}"

        set -- $(get_monitor_info "$monitor_main")
        mode_main="$1"
        rate_main="$2"

        set -- $(get_monitor_info "$monitor_sec")
        mode_sec="$1"
        rate_sec="$2"

        # Build xrandr command based on SEC_POSITION
        xrandr_cmd="xrandr --output \"$monitor_main\" --primary --mode \"$mode_main\" --pos 0x0 --auto --rate \"$rate_main\""
        
        case "$SEC_POSITION" in
            "left-of")
                xrandr_cmd="$xrandr_cmd --output \"$monitor_sec\" --mode \"$mode_sec\" --left-of \"$monitor_main\" --auto --rate \"$rate_sec\""
                ;;
            "right-of")
                xrandr_cmd="$xrandr_cmd --output \"$monitor_sec\" --mode \"$mode_sec\" --right-of \"$monitor_main\" --auto --rate \"$rate_sec\""
                ;;
            "above")
                xrandr_cmd="$xrandr_cmd --output \"$monitor_sec\" --mode \"$mode_sec\" --above \"$monitor_main\" --auto --rate \"$rate_sec\""
                ;;
            "below")
                xrandr_cmd="$xrandr_cmd --output \"$monitor_sec\" --mode \"$mode_sec\" --below \"$monitor_main\" --auto --rate \"$rate_sec\""
                ;;
            *)
                # Default to left-of
                xrandr_cmd="$xrandr_cmd --output \"$monitor_sec\" --mode \"$mode_sec\" --left-of \"$monitor_main\" --auto --rate \"$rate_sec\""
                ;;
        esac
        
        eval "$xrandr_cmd"

        bspc monitor "$monitor_main" -d $MAIN_WORKSPACES
        bspc monitor "$monitor_sec" -d $SEC_WORKSPACES
        bspc wm -O "$monitor_main" "$monitor_sec"
        SetMonoclePadding "$monitor_main"
        SetMonoclePadding "$monitor_sec"
        ;;

    3)
        monitor_1="${MONITOR_MAIN:-$1}"
        monitor_2="$2"
        monitor_3="$3"

        set -- $(get_monitor_info "$monitor_1")
        mode_1="$1"
        rate_1="$2"

        set -- $(get_monitor_info "$monitor_2")
        mode_2="$1"
        rate_2="$2"

        set -- $(get_monitor_info "$monitor_3")
        mode_3="$1"
        rate_3="$2"

        xrandr --output "$monitor_1" --primary --mode "$mode_1" --pos 0x0 --auto --rate "$rate_1" \
               --output "$monitor_2" --mode "$mode_2" --left-of "$monitor_1" --auto --rate "$rate_2" \
               --output "$monitor_3" --mode "$mode_3" --right-of "$monitor_1" --auto --rate "$rate_3"

        bspc monitor "$monitor_1" -d 1 2 3
        bspc monitor "$monitor_2" -d 4 5 6
        bspc monitor "$monitor_3" -d 7 8 9
        bspc wm -O "$monitor_1" "$monitor_2" "$monitor_3"
        SetMonoclePadding "$monitor_1"
        SetMonoclePadding "$monitor_2"
        SetMonoclePadding "$monitor_3"
        ;;

    4)
        monitor_1="${MONITOR_MAIN:-$1}"
        monitor_2="$2"
        monitor_3="$3"
        monitor_4="$4"

        set -- $(get_monitor_info "$monitor_1")
        mode_1="$1"
        rate_1="$2"

        set -- $(get_monitor_info "$monitor_2")
        mode_2="$1"
        rate_2="$2"

        set -- $(get_monitor_info "$monitor_3")
        mode_3="$1"
        rate_3="$2"

        set -- $(get_monitor_info "$monitor_4")
        mode_4="$1"
        rate_4="$2"

        xrandr --output "$monitor_1" --primary --mode "$mode_1" --pos 0x0 --auto --rate "$rate_1" \
               --output "$monitor_2" --mode "$mode_2" --left-of "$monitor_1" --auto --rate "$rate_2" \
               --output "$monitor_3" --mode "$mode_3" --right-of "$monitor_1" --auto --rate "$rate_3" \
               --output "$monitor_4" --mode "$mode_4" --above "$monitor_1" --auto --rate "$rate_4"

        bspc monitor "$monitor_1" -d 1 2 3
        bspc monitor "$monitor_2" -d 4 5
        bspc monitor "$monitor_3" -d 6 7
        bspc monitor "$monitor_4" -d 8 9
        bspc wm -O "$monitor_1" "$monitor_2" "$monitor_3" "$monitor_4"
        SetMonoclePadding "$monitor_1"
        SetMonoclePadding "$monitor_2"
        SetMonoclePadding "$monitor_3"
        SetMonoclePadding "$monitor_4"
        ;;

    *)
        echo "Warning: Configuration not supported for more than 4 monitors"
        ;;
esac

# Apply HDR configuration if enabled
if [ "$HDR_ENABLE" = "true" ] && [ -n "$HDR_MONITOR" ]; then
    # Check if the HDR monitor is connected
    if echo "$XRANDR_OUTPUT" | grep -q "^$HDR_MONITOR connected"; then
        echo "Enabling HDR on $HDR_MONITOR..."
        # Enable HDR using xrandr
        xrandr --output "$HDR_MONITOR" --set HDR on 2>/dev/null || \
            echo "Note: HDR property may not be supported by this display driver"
    else
        echo "Warning: HDR monitor $HDR_MONITOR is not connected"
    fi
fi
