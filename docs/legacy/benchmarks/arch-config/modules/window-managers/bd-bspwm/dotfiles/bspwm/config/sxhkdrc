    OpenApps --{terminal,floating}

# Open kitty with session selector
super + shift + Return
    KittySessionPicker

# Open kitty with felix split pane
super + alt + Return
    kitty --session ~/.config/kitty/sessions/felix.session

# App launcher
super + @space
    OpenApps --menu

# Theme Selector
alt + @space
    RiceSelector

# ----- Your Apps ----- #

# Apps (browser, editor, filemanager)
