# Enable Super Keys For Menu
ksuperkey -e 'Super_L=Alt_L|F1' &
ksuperkey -e 'Super_R=Alt_L|F1' &

# Enable power management
xfce4-power-manager &

# Load X resources (includes cursor theme)
xrdb -merge ~/.Xresources

# Restore wallpaper
